---
import "../styles/global.scss";

// Astroのbase設定を含めた正しいURLを作るために使います。
// GitHub Pagesなどで /baazusalon/ 配下に公開しても画像パスが壊れにくくなります。
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<link rel="preconnect" href="https://api.fontshare.com" />
		<link
			href="https://api.fontshare.com/v2/css?f[]=recia@400,700&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
			rel="stylesheet"
		/>
		<title>båzu frisør</title>
	</head>
	<!-- bg img setting -->
	<body style={`--site-bg: url('${base}img/bg/bg9.jpg')`}>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
