---
const heroImages = Array.from(
    { length: 14 },
    (_, i) => `/img/hero/${i + 1}.jpg`,
);
const randomImage = heroImages[Math.floor(Math.random() * heroImages.length)];
---

<section class="hero">
    <div class="hero__content">
        <p class="hero__eyebrow">båzu frisør</p>
        <h1 class="hero__title">
            One millimeter<br />changes the impression.
        </h1>
        <p class="hero__sub">
            Short cuts, measured from 1 to 20 millimeters.<br />
            See your length before you decide.<br />
            Choose what fits your shape.
        </p>
        <div class="hero__cta">
            <a href="#slider" class="btn btn--primary">Find your length</a>
            <a href="#booking" class="btn btn--ghost">Book directly ➡︎</a>
        </div>
    </div>
    <div class="hero__image">
        <img id="hero-img-a" src={randomImage} alt="buzz cut portrait" />
        <img id="hero-img-b" src={heroImages[1]} alt="buzz cut portrait" />
    </div>
</section>

<style lang="scss">
    .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 5.5rem 0 4rem 5rem;
        overflow: hidden;
    }
    .hero__eyebrow {
        margin-bottom: 1.25rem;
        color: var(--color-dark);
        font-family: "Recia", serif;
        font-size: clamp(1.5rem, 2vw, 2rem);
        line-height: 1;
        letter-spacing: 0;
        text-transform: none;
    }
    .hero__title {
        font-family: "Recia", serif;
        font-size: clamp(2rem, 4vw, 4.6rem);
        line-height: 1.1;
        margin-bottom: 1.5rem;
    }
    .hero__sub {
        font-size: 1rem;
        line-height: 1.85;
        max-width: 430px;
        margin-bottom: 2rem;
    }

    .hero__cta {
        display: flex;
        gap: 1rem;
        align-items: center;
        margin-top: 1rem;
        margin-bottom: 1rem;
    }
    .hero__content {
        flex: 1;
        max-width: 480px;
        position: relative;
        z-index: 1;
        &::before {
            content: "坊主";
            position: absolute;
            top: -5rem;
            left: -2rem;
            z-index: -1;
            color: rgba(78, 54, 32, 0.1);
            font-family: serif;
            font-size: clamp(7rem, 16vw, 14rem);
            line-height: 1;
            pointer-events: none;
            white-space: nowrap;
        }
    }

    .hero__image {
        flex: 1.2;
        margin-left: -4rem;
        position: relative;
        height: 85vh;
        mask-image: linear-gradient(to right, transparent 0%, black 25%);

        img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: contain;
            transition: opacity 0.6s ease;

            &#hero-img-b {
                opacity: 0;
            }
        }
    }
</style>

<script>
    const base = import.meta.env.BASE_URL;
    const images = Array.from(
        { length: 14 },
        (_, i) => `${base}img/hero/${i + 1}.jpg`,
    );

    images.forEach((src) => {
        const preload = new Image();
        preload.src = src;
    });

    let current = 0;
    let showingA = true;

    const imgA = document.getElementById("hero-img-a");
    const imgB = document.getElementById("hero-img-b");

    setInterval(() => {
        current = (current + 1) % images.length;

        if (showingA) {
            imgB.src = images[current];
            imgB.style.opacity = "1";
            imgA.style.opacity = "0";
        } else {
            imgA.src = images[current];
            imgA.style.opacity = "1";
            imgB.style.opacity = "0";
        }

        showingA = !showingA;
    }, 3000);
</script>
