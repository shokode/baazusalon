---
const base = import.meta.env.BASE_URL;

const lengthSteps = ["1mm", "2mm", "3mm", "5mm", "10mm", "15mm", "20mm"];
---

<section class="section length-slider" id="slider">
    <div class="container">
        <div class="section-heading">
            <p class="section-heading__label">Length study</p>

            <h2 class="section-heading__title">Find your length.</h2>

            <p class="section-heading__text">
                Slide to see how each millimeter changes the look.
            </p>
        </div>

        <div class="length-slider__layout">
            <div class="length-slider__image">
                <img
                    class="is-visible"
                    src={`${base}img/slider/bozu3.png`}
                    alt="Buzz cut length preview"
                    data-length-image-a
                />
                <img
                    src={`${base}img/slider/bozu3.png`}
                    alt=""
                    aria-hidden="true"
                    data-length-image-b
                />
            </div>

            <div class="length-slider__controls">
                <p class="length-slider__value" data-length-value>3mm</p>

                <p class="length-slider__description" data-length-description>
                    Classic and clean. The most popular choice.
                </p>

                <p class="length-slider__note">
                    Around 6mm, the scalp is usually only subtly visible,
                    depending on hair density.
                </p>

                <input
                    class="length-slider__range"
                    type="range"
                    min="0"
                    max="6"
                    value="2"
                    step="1"
                    data-length-range
                />
                <div class="length-slider__steps" data-length-steps>
                    {
                        lengthSteps.map((length, index) => (
                            <button
                                type="button"
                                data-length-step={index}
                                class={index === 2 ? "is-active" : ""}
                            >
                                {length}
                            </button>
                        ))
                    }
                </div>

                <a class="btn btn--primary" href="#booking" data-length-book>
                    Book this length
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    .length-slider__layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 4rem;
        align-items: center;
        margin-top: 4rem;
    }

    .length-slider__image {
        position: relative;
        min-height: 520px;
        border: 1px solid rgba(78, 54, 32, 0.18);
        background-color: rgba(248, 244, 225, 0.72);
    }

    .length-slider__image img {
        position: absolute;
        inset: 3rem;
        width: calc(100% - 6rem);
        height: calc(100% - 6rem);
        max-height: none;
        object-fit: contain;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .length-slider__image img.is-visible {
        opacity: 1;
    }

    .length-slider__value {
        font-family: "Recia", serif;
        font-size: clamp(3rem, 7vw, 5rem);
        line-height: 1;
    }

    .length-slider__description {
        margin-top: 1rem;
        min-height: 3.6em;
        color: var(--color-muted);
        line-height: 1.8;
    }

    .length-slider__note {
        margin-top: 1rem;
        color: var(--color-muted);
        font-size: 0.85rem;
        line-height: 1.6;
    }

    .length-slider__range {
        width: 100%;
        margin: 2rem 0;
        accent-color: var(--color-dark-accent);
    }
    .length-slider__steps {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.5rem;
        margin-bottom: 2rem;

        button {
            padding: 0.45rem 0.65rem;
            border: 1px solid rgba(78, 54, 32, 0.18);
            background: transparent;
            color: var(--color-muted);
            font: inherit;
            font-size: 0.8rem;
            cursor: pointer;
        }

        button.is-active {
            border-color: var(--color-dark);
            background-color: var(--color-dark);
            color: var(--color-light);
        }
    }
</style>

<script>
    const base = import.meta.env.BASE_URL;
    const lengths = [
        {
            label: "1mm",
            image: `${base}img/slider/bozu1.png`,
            description: "The boldest choice. Skin shows through.",
        },
        {
            label: "2mm",
            image: `${base}img/slider/bozu2.png`,
            description: "Just a hint softer than 1mm.",
        },
        {
            label: "3mm",
            image: `${base}img/slider/bozu3.png`,
            description: "Classic and clean. The most popular choice.",
        },
        {
            label: "5mm",
            image: `${base}img/slider/bozu4.png`,
            description: "Short but soft. A safe first cut.",
        },
        {
            label: "10mm",
            image: `${base}img/slider/bozu5.png`,
            description: "Buzz cut territory. Subtle and easy.",
        },
        {
            label: "15mm",
            image: `${base}img/slider/bozu6.png`,
            description: "Short hair, still styled.",
        },
        {
            label: "20mm",
            image: `${base}img/slider/bozu7.png`,
            description: "The longest of the short. Works anywhere.",
        },
    ];
    const imageA = document.querySelector("[data-length-image-a]");
    const imageB = document.querySelector("[data-length-image-b]");
    const valueEl = document.querySelector("[data-length-value]");
    const descriptionEl = document.querySelector("[data-length-description]");
    const rangeEl = document.querySelector("[data-length-range]");
    const bookEl = document.querySelector("[data-length-book]");
    const stepButtons = document.querySelectorAll("[data-length-step]");
    let showingA = true;

    function renderLength(index) {
        const current = lengths[index];
        const visibleImage = showingA ? imageA : imageB;
        const hiddenImage = showingA ? imageB : imageA;

        hiddenImage.src = current.image;
        hiddenImage.classList.add("is-visible");
        visibleImage.classList.remove("is-visible");
        valueEl.textContent = current.label;
        descriptionEl.textContent = current.description;
        rangeEl.value = index;
        showingA = !showingA;
        bookEl.dataset.selectedLength = current.label;

        stepButtons.forEach((button) => {
            button.classList.toggle(
                "is-active",
                button.dataset.lengthStep === String(index),
            );
        });
    }

    rangeEl.addEventListener("input", () => {
        renderLength(Number(rangeEl.value));
    });

    stepButtons.forEach((button) => {
        button.addEventListener("click", () => {
            renderLength(Number(button.dataset.lengthStep));
        });
    });

    document.addEventListener("click", (event) => {
        const trigger = event.target.closest("[data-see-slider]");

        if (!trigger) return;

        const targetLength = trigger.dataset.length;
        const targetIndex = lengths.findIndex(
            (item) => item.label === targetLength,
        );

        if (targetIndex === -1) return;

        renderLength(targetIndex);
    });
</script>
